# ─── Application ──────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# ─── Database ─────────────────────────────────────────────────
# SQLite (default, no setup needed)
DATABASE_URL=sqlite:///./database/attendance.db

# PostgreSQL (uncomment + fill to switch)
# DATABASE_URL=postgresql://user:password@localhost:5432/attendance_db

# ─── Security ─────────────────────────────────────────────────
# CHANGE THIS to a random 256-bit string in production!
SECRET_KEY=change-me-to-a-secure-random-256bit-secret-key-in-production
TOKEN_EXPIRE_HOURS=24

# ─── OpenAI / GenAI ───────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ─── Face Recognition ─────────────────────────────────────────
FACE_TOLERANCE=0.5
MIN_FACE_IMAGES=10
FACE_IMAGES_DIR=database/face_images

# ─── Backup ───────────────────────────────────────────────────
BACKUP_DIR=backups
BACKUP_KEEP_DAYS=7
